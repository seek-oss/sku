{
  "extends": "@tsconfig/node24/tsconfig.json",
  "compilerOptions": {
    "module": "node18",
    "allowImportingTsExtensions": true,
    "allowJs": true,
    "jsx": "react-jsx",
    "noEmit": true,
    // Output incremental build info to a centralized cache.
    "outDir": "node_modules/.cache/tsc/root",
    "incremental": true,
    "resolveJsonModule": true
  },
  "include": ["**/*", "eslint.config.js", "types.d.ts"],
  "exclude": [
    "node_modules",
    "fixtures",
    "packages/sku",
    "packages/codemod",
    "packages/create",
    "packages/vite",
    "packages/pnpm-plugin",
    "packages/babel-plugin-display-name",
    "private/utils",
    "private/inject-changelog-preamble",
    "private/react-lib-with-loadable"
  ],
  "references": [
    { "path": "./packages/sku" },
    { "path": "./packages/codemod" },
    { "path": "./packages/create" },
    { "path": "./packages/vite" },
    { "path": "./packages/pnpm-plugin" },
    { "path": "./packages/babel-plugin-display-name" },
    { "path": "./private/utils" },
    { "path": "./private/inject-changelog-preamble" },
    { "path": "./private/react-lib-with-loadable" }
  ]
}
