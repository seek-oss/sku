{
  "extends": "@tsconfig/node22/tsconfig.json",
  "compilerOptions": {
    "rootDir": "./src",
    "noEmit": true,
    "allowImportingTsExtensions": true,
    "target": "ESNext",
    "module": "nodenext",
    "moduleResolution": "nodenext",
    "jsx": "react-jsx"
  },
  "include": ["./src/**/*"]
}
