{
  "name": "pnpm-plugin-sku",
  "version": "0.0.3",
  "description": "PNPM config dependency for sku that configures recommended PNPM settings",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.cts",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    },
    "./config": {
      "import": "./dist/config.mjs",
      "require": "./dist/config.cjs"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "pnpmfile.cjs",
    "pnpmfile.mjs"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/seek-oss/sku.git",
    "directory": "packages/pnpm-plugin"
  },
  "author": "SEEK",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/seek-oss/sku/issues"
  },
  "homepage": "https://github.com/seek-oss/sku#readme",
  "devDependencies": {
    "@pnpm/config": "^1004.11.0"
  }
}
